# Google Cloud Platform
GCP_PROJECT_ID=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS is not needed when using ADC
# GOOGLE_APPLICATION_CREDENTIALS=/workspace/.secrets/service-account-key.json

# BigQuery Datasets
GCP_DATASET_RAW=raw
GCP_DATASET_STAGING=staging
GCP_DATASET_CORE=core
GCP_DATASET_MARTS=marts
GCP_DATASET_METADATA=metadata

# Airflow
AIRFLOW_HOME=/workspace/airflow
AIRFLOW__CORE__DAGS_FOLDER=/workspace/dags
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__WEBSERVER__SECRET_KEY=your-dev-secret-key-here
