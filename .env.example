# Google Cloud Platform
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/workspace/.secrets/service-account-key.json

# BigQuery Dataset Names
BQ_DATASET_RAW=raw
BQ_DATASET_STAGING=staging
BQ_DATASET_CORE=core
BQ_DATASET_MARTS=marts
BQ_DATASET_METADATA=metadata

# Airflow
AIRFLOW_HOME=/workspace/airflow
AIRFLOW__CORE__DAGS_FOLDER=/workspace/dags
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__WEBSERVER__SECRET_KEY=donor-platform-dev-key
